#compdef cortex
# cortex-cli-completion-version: 1.1.1+001046.4c040d09e2a2

_cortex() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(-w --workdir)'{-w,--workdir}'[Working directory]:directory:_directories' \
        '--mount[Additional mount for sandbox VM (hostPath=<path>,mountPath=<path>\[,ro\]). May be repeated.]:mount:' \
        '(-c --connection)'{-c,--connection}'[Snowflake connection name]:connection:' \
        '(-m --model)'{-m,--model}'[Model override]:model:' \
        '--mode[Agent mode: '\''standard'\'' or '\''code'\'']:mode:' \
        '--plan[Enable plan mode]' \
        '--goal[Run the provided prompt as a goal and submit it as the first headless message]:goal:' \
        '--sql-read-only[Start the session with the built-in SQL tool in read-only mode (rejects DDL/DML via CORTEX_CLIENT_READ_ONLY). Toggle at runtime with /sql-readonly on|off.]' \
        '--bypass[Enable bypass safeguards mode (auto-approve all tool calls)]' \
        '--dangerously-allow-all-tool-calls[Enable bypass safeguards mode (auto-approve all tool calls)]' \
        '--auto-accept-plans[Auto-accept plan mode requests and confirmations without prompting]' \
        '--profile[Apply a profile configuration (from ~/.snowflake/cortex/profiles/)]:profile:' \
        '(-r --resume)'{-r,--resume}'[Open the resume menu on startup or immediately resume a session by session ID]:resume:' \
        '--continue[Resume the most recent session]' \
        '--session-name[Name for the new session (ignored when resuming)]:session-name:' \
        '--session-id[Set the session ID for a new session (ignored when resuming)]:session-id:' \
        '--fork-session[When resuming, fork to a new session instead of continuing the existing one]' \
        '--fork[Fork an existing session into a new one. In TUI: opens the message picker to choose where to fork from. In --print/--input-format stream-json: forks the full history (equivalent to --resume <id> --fork-session).]:fork:' \
        '--resume-session-at[When forking a resumed session, truncate history at this message ID (requires --fork-session and --resume)]:resume-session-at:' \
        '--setting-sources[Comma-separated list of setting sources to load: user, project. Empty string disables all.]:setting-sources:' \
        '--output-format[Output format: '\''stream-json'\'' for JSON streaming output]:output-format:' \
        '--input-format[Input format: '\''stream-json'\'' for JSON stdin input (use with --output-format stream-json)]:input-format:' \
        '(-p --print)'{-p,--print}'[Print a series of chat response and exit (in headless, non-interactive mode)]:print:' \
        '--config[Path to a custom settings.json configuration file (default: ~/.snowflake/cortex/settings.json)]:file:_files' \
        '--config-file[Path to Snowflake connection config file (connections.toml or config.toml)]:config-file:' \
        '--skills[Path to a custom skills.json configuration file (default: ~/.snowflake/cortex/skills.json)]:file:_files' \
        '--mcp[Enable MCP servers (use --no-mcp to disable)]' \
        '--auto-update[Auto-update on launch (use --no-auto-update to disable)]' \
        '--worktree[Create a new worktree with the specified branch name and start session in it]:worktree:' \
        '--plugin-dir[Plugin directory or GitHub repo (owner/repo, owner/repo#branch, or URL). Can be repeated.]:plugin-dir:' \
        '--shell[Shell executor for commands: '\''powershell'\'', '\''cmd'\'', or '\''bash'\'' (default: auto-detect; on Windows defaults to powershell)]:shell:' \
        '--allowed-tools[Tools that execute without prompting for permission (e.g. "Bash(git *)" "Read" "Edit")]:allowed-tools:' \
        '--disallowed-tools[Tools that are removed from the model'\''s context and cannot be used (e.g. "Bash(rm *)" "Task(Explore)")]:disallowed-tools:' \
        '(-V --version)'{-V,--version}'[Show version]' \
        '--snowflake-sandbox[Enable Snowflake server-side sandbox for coding agent (requires Snowhouse connection or dev mode)]' \
        '--include-partial-messages[Include partial message events for token-level streaming]' \
        '--max-turns[Maximum number of agentic turns per conversation round]' \
        '--effort[Thinking effort level: minimal, low, medium, high, or max]:effort:' \
        '--agent[Use a custom agent definition by name (from .cortex/agents/ or ~/.snowflake/cortex/agents/)]:agent:' \
        '--index[Build tgrep semantic search index on startup]' \
        '--team[Enable teams mode (loads team-workflow skill on startup)]' \
        '--mcp-config[MCP server configuration as a JSON string (e.g. '\''{"mcpServers": {"server-name": {"type": "stdio", "command": "cmd"}}}'\'')]:mcp-config:' \
        '(-h --help)'{-h,--help}'[Show help]' \
        '1: :->commands' \
        '*: :->args' \
        && return 0

    case $state in
        commands)
            local commands=(
                'mcp:Manage MCP servers'
                'acp:Agent Client Protocol (ACP) commands'
                'profile:Manage profiles'
                'skill:Manage skill directories'
                'ctx:Long-term AI memory and task management'
                'resume:Resume a previous session'
                'update:Update to latest version'
                'versions:List locally installed versions'
                'worktree:Manage git worktrees'
                'completion:Shell completion scripts'
                'create-ui-launcher:Build and install the macOS desktop web UI launcher'
                'connections:Manage Snowflake connections'
                'search:Search Snowflake objects or docs'
                'reflect:Validate semantic model'
                'artifact:Artifact operations'
                'analyst:Cortex Analyst operations'
                'env:Environment detection'
                'agents:Discover and explore Cortex Agents'
                'lineage:Show upstream and downstream lineage for a Snowflake object'
                'airflow:Interact with Apache Airflow'
            )
            _describe 'commands' commands
            ;;
    esac
}

_cortex "$@"
